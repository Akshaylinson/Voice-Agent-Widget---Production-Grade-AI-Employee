# Multi-Tenant Configuration
DATABASE_URL=postgresql://postgres:postgres@db:5432/voice_agent_multi_tenant

# Encryption Key for API Keys (Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-encryption-key-here

# Master Admin Authentication (Future)
MASTER_ADMIN_SECRET=your-master-admin-secret

# Service Configuration
API_TIMEOUT=60
LOG_LEVEL=INFO
CORS_ORIGINS=*
